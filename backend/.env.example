# GradLaunch Backend Environment
# 1. Copy this file: cp .env.example .env
# 2. Fill in the FREE API keys below
# All keys marked [FREE] have no cost and work with free tier

# ========== REQUIRED ==========
JWT_SECRET=gradlaunch_secret_key_2026
NODE_ENV=development

# ========== DATABASE (Turso - Cloud SQLite) ==========
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_auth_token

# ========== AI & RESUME OPTIMIZATION ==========
# Google Gemini API [FREE] - 50 requests/day
# Get at: https://console.google.com/generativeai
GEMINI_API_KEY=

# Anthropic Claude API [Optional] - $5 free credits/month
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ========== JOB SEARCH APIs [FREE] ==========

# 1. Careerjet AffID [FREE] - Worldwide job listings
# Get at: https://www.careerjet.com/partners/
CAREERJET_AFFID=

# 2. JSearch via RapidAPI [FREE] - 100 req/month
# Get at: https://rapidapi.com/letscrape-6bR7n6u7pxu/api/jsearch/
RAPIDAPI_KEY=


# 3. Adzuna API [FREE] - Job aggregator + salary data, 100 calls/day
# Get at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# 4. Findwork API [Optional] - Freelance + job listings
# Get at: https://findwork.dev/
FINDWORK_API_KEY=

# ========== OPTIONAL INTEGRATIONS ==========
API_KEY_21ST=an_sk_your_key_here
